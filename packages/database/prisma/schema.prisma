// Prisma schema for Powerstarter
// Mirrors the InstanceResult family of interfaces from
// packages/ui/src/types/instance-result.ts
//
// All JSON columns (bms, unity, tags) are stored as native JSON so that the
// application layer can deserialise them back to their typed shapes without
// extra relational joins.  This matches the flat InstanceResult contract that
// the Unity game interface and Powerframe BMS engine both consume.

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Instance – top-level record
// ---------------------------------------------------------------------------

/// Lifecycle state of a Powerstarter instance.
enum InstanceStatus {
  active
  inactive
  pending
  error
}

/// The authoritative persisted record for a single Powerstarter instance.
/// Matches the InstanceResult TypeScript interface exactly.
model Instance {
  /// UUID v4 primary key, generated by the application layer.
  id        String         @id @db.Uuid
  /// Human-readable name (e.g. "Pack A – Rack 3").
  name      String         @db.VarChar(100)
  /// Current lifecycle status.
  status    InstanceStatus @default(active)
  /// ISO-8601 timestamp of record creation (application-supplied).
  createdAt DateTime       @map("created_at") @db.Timestamptz
  /// ISO-8601 timestamp of most recent update (application-supplied).
  updatedAt DateTime       @map("updated_at") @db.Timestamptz

  /// Powerframe BMS metrics stored as a JSON blob.
  /// Shape: BmsMetrics | null  (see packages/ui/src/types/instance-result.ts)
  bms  Json?

  /// Unity display data stored as a JSON blob.
  /// Shape: UnityDisplayData | null
  unity Json?

  /// Optional free-form tags for filtering in the portfolio UI.
  tags String[]

  /// Whether this instance is published to the Community feed.
  isPublic  Boolean @default(false) @map("is_public")

  /// URL-safe slug for the shareable portfolio link (e.g. "pack-a-rack-3").
  /// Unique across all instances; null until the owner publishes.
  slug      String? @unique

  @@map("instances")
}
